# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.devenv/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# App icons are generated from assets/icon/app_icon.svg by
# tool/generate_app_icon.py at build time. Do not commit the rasterized PNGs.
/android/app/src/main/res/mipmap-*/ic_launcher.png
/ios/Runner/Assets.xcassets/AppIcon.appiconset/Icon-App-*.png
/web/favicon.png
/web/icons/Icon-*.png

# Real GTFS feeds downloaded by tool/fetch_gtfs at runtime. These are large
# (Toei Bus alone is ~6 MB compressed / ~70 MB unzipped) and re-published
# frequently by upstream. The small CI-friendly slice lives under
# assets/sample_toei_train/ and is committed.
/assets/real_gtfs/

# Shared library output from cmd/libtransitplanner (c-shared build).
/build/libtransit_planner.*
/build/transit_planner.*

# Android Go FFI artifact dropped in by CI (build-go-android job). Never
# commit these; the SHA changes with every Go toolchain and Toei feed
# update, so they would just produce binary diff noise.
/android/app/src/main/jniLibs/
